# ==========================================
# GoAuth Environment Configuration Example
# ==========================================

# App Configuration
APP_ENV=development
APP_PORT=8080

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_local_db_password_here
DB_NAME=goauth

# Cryptography & Tokens
# NOTE: Use RS256 format. Newlines must be handled correctly depending on your deployment.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_DUMMY_PRIVATE_KEY\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_DUMMY_PUBLIC_KEY\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h

# Server Resilience & Security (Fast Apps)
RATE_LIMIT_PER_MIN=100
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
READ_TIMEOUT=10
WRITE_TIMEOUT=10
SHUTDOWN_TIMEOUT=15